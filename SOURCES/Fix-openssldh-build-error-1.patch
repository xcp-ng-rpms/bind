Applied fix of upstream

From 76af83c9adb772f7b045c62cf8b411165bfaa5ef Mon Sep 17 00:00:00 2001
From: Mark Andrews <marka@isc.org>
Date: Mon, 31 Oct 2016 10:04:37 +1100
Subject: [PATCH] 4497.   [port]          Add support for OpenSSL 1.1.0.
[RT #41284]

(cherry picked from commit 1fce0951ed172fc3834a3a379c4e00b78224cc5d)
---
 lib/dns/openssl_link.c   |   4 +-
 lib/dns/openssldh_link.c | 248 ++++++++++++++++++++++-----------------
 2 files changed, 145 insertions(+), 107 deletions(-)

diff --git a/lib/dns/openssl_link.c b/lib/dns/openssl_link.c
index 56465aa..95edaba 100644
--- a/lib/dns/openssl_link.c
+++ b/lib/dns/openssl_link.c
@@ -290,7 +290,7 @@ static isc_result_t
 toresult(isc_result_t fallback) {
 	isc_result_t result = fallback;
 	unsigned long err = ERR_get_error();
-#ifdef HAVE_OPENSSL_ECDSA
+#ifdef ECDSA_R_RANDOM_NUMBER_GENERATION_FAILED
 	int lib = ERR_GET_LIB(err);
 #endif
 	int reason = ERR_GET_REASON(err);
@@ -304,7 +304,7 @@ toresult(isc_result_t fallback) {
 		result = ISC_R_NOMEMORY;
 		break;
 	default:
-#ifdef HAVE_OPENSSL_ECDSA
+#ifdef ECDSA_R_RANDOM_NUMBER_GENERATION_FAILED
 		if (lib == ERR_R_ECDSA_LIB &&
 		    reason == ECDSA_R_RANDOM_NUMBER_GENERATION_FAILED) {
 			result = ISC_R_NOENTROPY;
diff --git a/lib/dns/openssldh_link.c b/lib/dns/openssldh_link.c
index f0cee8d..bd7282e 100644
